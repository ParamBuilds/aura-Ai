# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI API calls from the client.
# AI Studio automatically injects this at runtime from user secrets.
NEXT_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Secure key (Server-side only)
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"
# Public flag to enable OpenRouter features
NEXT_PUBLIC_ENABLE_OPENROUTER="true"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
